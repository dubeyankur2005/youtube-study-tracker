{
  "manifest_version": 3,

  "name": "YouTube Study Tracker",

  "version": "1.0",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],

      "js": [
        "content.js"
      ]
    }
  ]
}